PORT=3000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/jobforge
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_URLS=http://localhost:5173
NODE_ENV=development

# Cloudinary (https://cloudinary.com)
CLOUD_NAME=your-cloudinary-cloud-name
API_KEY=your-cloudinary-api-key
API_SECRET=your-cloudinary-api-secret

# Rate Limiting
RATE_LIMIT_MAX=300

# AI Job Match Score (optional - get free key at https://aistudio.google.com)
# If not set, a keyword-matching fallback is used automatically
GEMINI_API_KEY=

# Email / SMTP (optional - for sending interview invitation emails)
# If not set, Ethereal sandbox is used in development (preview in terminal logs)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
